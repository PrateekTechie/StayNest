<% layout('layouts/boilerplate.ejs') %>

<div class="py-4">
    <div class="row g-4">

        <div class="col-lg-7">
            <div class="panel-card p-4 p-md-5">

                <h3 class="fw-bold mb-3">Complete your Booking</h3>

                <p class="text-muted mb-2">
                    <strong><%= listing.title %></strong>
                </p>

                <p class="mb-2">
                    <i class="fa-solid fa-calendar-days me-2"></i>
                    Check-in:
                    <%= booking.checkIn.toDateString() %>
                </p>

                <p class="mb-2">
                    <i class="fa-solid fa-calendar-days me-2"></i>
                    Check-out:
                    <%= booking.checkOut.toDateString() %>
                </p>

                <p class="mb-2">
                    <i class="fa-solid fa-users me-2"></i>
                    Guests:
                    <%= booking.guestsCount %>
                </p>

                <p class="mb-4">
                    <i class="fa-solid fa-wallet me-2"></i>
                    Total Amount:
                    <strong>₹<%= booking.totalAmount.toLocaleString("en-IN") %></strong>
                </p>

                <button id="rzp-button" class="btn btn-airbnb w-100">
                    Pay with Razorpay
                </button>

            </div>
        </div>

        <div class="col-lg-5">
            <div class="panel-card p-4 p-md-5">

                <h5 class="fw-bold mb-3">Booking Summary</h5>

                <p>
                    Price per night:
                    ₹<%= booking.pricePerNight.toLocaleString("en-IN") %>
                </p>

                <p>
                    Cleaning Fee:
                    ₹<%= booking.cleaningFee.toLocaleString("en-IN") %>
                </p>

                <p>
                    Service Fee:
                    ₹<%= booking.serviceFee.toLocaleString("en-IN") %>
                </p>

                <p>
                    Taxes:
                    ₹<%= booking.taxes.toLocaleString("en-IN") %>
                </p>

                <hr>

                <h5 class="fw-bold">
                    Total:
                    ₹<%= booking.totalAmount.toLocaleString("en-IN") %>
                </h5>

            </div>
        </div>

    </div>
</div>

<script src="https://checkout.razorpay.com/v1/checkout.js"></script>

<script>

const options = {

    key: "<%= razorpayKey %>",

    amount: <%= booking.totalAmount * 100 %>,

    currency: "INR",

    name: "StayNest",

    description: "Booking Payment",

    order_id: "<%= order.id %>",

    theme: {
        color: "#ff5a5f"
    },

    handler: function (response) {

        const form = document.createElement("form");

        form.method = "POST";
        form.action = "/payments/verify-payment";

        form.innerHTML = `
            <input type="hidden" name="bookingId" value="<%= booking._id %>">
            <input type="hidden" name="razorpay_order_id" value="${response.razorpay_order_id}">
            <input type="hidden" name="razorpay_payment_id" value="${response.razorpay_payment_id}">
            <input type="hidden" name="razorpay_signature" value="${response.razorpay_signature}">
        `;

        document.body.appendChild(form);
        form.submit();
    }

};

const btn = document.getElementById("rzp-button");

btn.onclick = function (e) {

    e.preventDefault();

    btn.disabled = true;
    btn.innerHTML = "Processing...";

    const rzp = new Razorpay(options);

    rzp.on("payment.failed", function (response) {

        alert("Payment Failed!\n\n" + response.error.description);

        btn.disabled = false;
        btn.innerHTML = "Pay with Razorpay";

    });

    rzp.open();

};

</script>