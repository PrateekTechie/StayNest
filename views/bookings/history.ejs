<% layout('layouts/boilerplate.ejs') %>
<div class="container mt-4">
  <h3>My Trips</h3>
  <% if (bookings.length === 0) { %>
    <p>No bookings yet.</p>
  <% } else { %>
    <div class="table-responsive">
      <table class="table table-bordered">
        <thead>
          <tr>
            <th>Listing</th>
            <th>Dates</th>
            <th>Amount</th>
            <th>Booking</th>
            <th>Payment</th>
            <th>Order ID</th>
            <th>Payment ID</th>
          </tr>
        </thead>
        <tbody>
          <% bookings.forEach(booking => { %>
            <tr>
              <td><%= booking.listing && booking.listing.title %></td>
              <td><%= booking.checkIn.toDateString() %> → <%= booking.checkOut.toDateString() %></td>
              <td>₹<%= booking.totalAmount.toLocaleString("en-IN") %></td>
              <td><%= booking.bookingStatus %></td>
              <td><%= booking.paymentStatus %></td>
              <td><%= booking.orderId || "—" %></td>
              <td><%= booking.paymentId || "—" %></td>
              <td><a href="/payments/invoice/<%= booking._id %>" class="btn btn-sm btn-outline-primary">Download Invoice</a></td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  <% } %>
</div>
