<style>
.btn-search{
    background:linear-gradient(135deg,#ff5a5f,#ff7a7d);
    color:#fff;
    border:none;
    border-radius:999px;
    padding:.65rem 1rem;
    font-weight:600;
}

.btn-search:hover{
    color:#fff;
}

.btn-search i{
    margin-right:8px;
}

.search-input{
    width:100%;
    max-width:360px;
    border-radius:999px;
    padding-left:1rem;
}

.search-input{
    width:380px;
    border-radius:999px;
    padding-left:18px;
}

.nav-pill{
    border-radius:999px;
    padding:.45rem .8rem;
}

.nav-pill:hover{
    background:rgba(255,90,95,.08);
}
</style>

<%
const user = typeof currentUser !== "undefined" ? currentUser : null;
%>

<nav class="navbar navbar-expand-lg sticky-top">
    <div class="container-fluid">

        <a class="navbar-brand d-flex align-items-center gap-2" href="/listings">
            <i class="fa-solid fa-people-roof"></i>
            <span>StayNest</span>
        </a>

        <button class="navbar-toggler" type="button"
            data-bs-toggle="collapse"
            data-bs-target="#navbarNavAltMarkup">
            <span class="navbar-toggler-icon"></span>
        </button>

       <div class="collapse navbar-collapse" id="navbarNavAltMarkup">

    <!-- Left -->
    <div class="navbar-nav">
        <a class="nav-link nav-pill" href="/listings">Explore</a>
        <a class="nav-link nav-pill" href="/listings/new">Host your Home</a>
    </div>

    <!-- Center -->
    <div class="mx-auto">
        <form id="navbar-search-form"
              class="d-flex search-form"
              action="/listings"
              method="GET">

            <input
                class="form-control search-input"
                type="search"
                name="search"
                placeholder="Search destinations..."
                autocomplete="off">

            <button
                id="search-submit-btn"
                class="btn btn-search"
                type="submit">
                <i class="fa-solid fa-magnifying-glass"></i>
                Search
            </button>

        </form>
    </div>

    <!-- Right -->
    <div class="navbar-nav ms-auto align-items-center">

        <% if(currentUser){ %>

            <a class="nav-link nav-pill" href="/payments/history">
                <i class="fa-solid fa-calendar-days me-1"></i>
                Trips
            </a>

            <a class="nav-link nav-pill" href="/user/logout">
                Logout
            </a>

        <% } else { %>

            <a class="nav-link nav-pill" href="/user/signup">
                Sign up
            </a>

            <a class="nav-link nav-pill" href="/user/login">
                Login
            </a>

        <% } %>

    </div>

</div>

    </div>
</nav>