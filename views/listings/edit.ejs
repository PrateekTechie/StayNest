<% layout('layouts/boilerplate.ejs') %>

<div class="row">
  <div class="col-8 offset-2">

    <h3>Edit your Listing</h3>

    <form method="POST" action="/listings/<%= listing._id %>?_method=PUT" class="needs-validation" novalidate 
      enctype="multipart/form-data">


      <div class="mb-3">
        <label for="title" class="form-label">Title</label>
        <input 
          type="text" 
          name="listing[title]" 
          value="<%= listing.title %>" 
          class="form-control" 
          required 
          placeholder="Enter the title"
        >
      </div>

      <div class="mb-3">
        <label for="description" class="form-label">Description</label>
        <textarea 
          name="listing[description]" 
          class="form-control" 
          required
          placeholder="Enter the short description"><%= listing.description %></textarea>
      </div>

      <div class="mb-3">
        <label for="price" class="form-label">Price</label>
        <input 
          type="number" 
          name="listing[price]" 
          value="<%= listing.price %>" 
          class="form-control" 
          required 
          min="0"
        >
      </div>
      <div class="mb-3">
    <label for="category" class="form-label">Category</label>

    <select name="listing[category]" class="form-select" required>

        <option value="Trending" <%= listing.category === "Trending" ? "selected" : "" %>>
            Trending
        </option>

        <option value="Room" <%= listing.category === "Room" ? "selected" : "" %>>
            Room
        </option>

        <option value="Iconic Cities" <%= listing.category === "Iconic Cities" ? "selected" : "" %>>
            Iconic Cities
        </option>

        <option value="Mountains" <%= listing.category === "Mountains" ? "selected" : "" %>>
            Mountains
        </option>

        <option value="Castles" <%= listing.category === "Castles" ? "selected" : "" %>>
            Castles
        </option>

        <option value="Arctic" <%= listing.category === "Arctic" ? "selected" : "" %>>
            Arctic
        </option>

        <option value="Beaches" <%= listing.category === "Beaches" ? "selected" : "" %>>
            Beaches
        </option>

        <option value="Camping" <%= listing.category === "Camping" ? "selected" : "" %>>
            Camping
        </option>

        <option value="Farms" <%= listing.category === "Farms" ? "selected" : "" %>>
            Farms
        </option>

        <option value="Villas" <%= listing.category === "Villas" ? "selected" : "" %>>
            Villas
        </option>

    </select>
</div>
 <div class="mb-3">
  Original Listing Image<br />
     <img src="<%= listing.image.url %>" alt="Listing Image" class="img-fluid">
</div>

<div class="mb-3">
    <label for="image" class="form-label">Upload New Image</label>

    <input
        type="file"
        name="listing[image]"
        class="form-control"
    >
</div>
      <div class="mb-3">
        <label for="location" class="form-label">Location</label>
        <input 
          type="text" 
          name="listing[location]" 
          value="<%= listing.location %>" 
          class="form-control" 
          required 
          placeholder="Enter the valid location"
        >
      </div>

      <div class="mb-3">
        <label for="country" class="form-label">Country</label>
        <input 
          type="text" 
          name="listing[country]" 
          value="<%= listing.country %>" 
          class="form-control" 
          required 
          placeholder="Enter the valid country"
        >
      </div>

      <br>

      <button class="btn btn-dark edit-btn">Edit</button>

    </form>

  </div>
</div>