<% layout('layouts/boilerplate.ejs') %>

<div class="hero-shell animate-fade-in">
    <div class="row align-items-center g-4">
        <div class="col-lg-7">
            <div class="d-flex align-items-center gap-2 mb-3">
                <span class="badge badge-soft rounded-pill px-3 py-2">Airbnb-inspired stays</span>
                <span class="text-muted">Premium comfort • Smart search • Instant booking</span>
            </div>
            <h1 class="display-6 fw-bold mb-3">Find a stay that feels like home, only better.</h1>
            <p class="text-muted mb-4">Discover hand-picked escapes, chic city flats, and peaceful retreats with effortless filters and curated recommendations.</p>
            <div class="d-flex flex-wrap gap-2">
                <a href="/listings?category=Beaches" class="category-chip"><i class="fa-solid fa-umbrella-beach"></i> Beach stays</a>
                <a href="/listings?category=Mountains" class="category-chip"><i class="fa-solid fa-mountain"></i> Mountain cabins</a>
                <a href="/listings?category=Villas" class="category-chip"><i class="fa-solid fa-building-columns"></i> Villas</a>
            </div>
        </div>
        <div class="col-lg-5">
            <div class="panel-card p-4">
                <h5 class="fw-bold mb-3">Popular this week</h5>
                <div class="d-flex justify-content-between mb-2"><span>Coastal escapes</span><strong>24 new</strong></div>
                <div class="d-flex justify-content-between mb-2"><span>Mountain retreats</span><strong>16 new</strong></div>
                <div class="d-flex justify-content-between"><span>City chic stays</span><strong>31 new</strong></div>
            </div>
        </div>
    </div>
</div>

<div class="d-flex flex-wrap align-items-center justify-content-between gap-3 mb-3">
    <div>
        <h4 class="fw-bold mb-1"><% if (smartMode) { %>Smart search results<% } else { %>Discover stays<% } %></h4>
        <p class="text-muted mb-0">
            <% if (searchQuery) { %><%= resultCount %> stay<%= resultCount === 1 ? '' : 's' %> found for “<%= searchQuery %>”.<% } else { %>Browse the best stays for your next getaway.<% } %>
        </p>
    </div>
    <div class="d-flex align-items-center gap-2 flex-wrap">
        <% if (searchQuery) { %><a href="/listings" class="btn btn-outline-airbnb btn-sm">Clear search</a><% } %>
        <form method="GET" action="/listings" class="d-flex align-items-center gap-2">
            <input type="hidden" name="search" value="<%= searchQuery %>">
            <input type="hidden" name="smart" value="<%= smartMode ? '1' : '' %>">
            <% if (selectedCategory) { %><input type="hidden" name="category" value="<%= selectedCategory %>"><% } %>
            <select class="form-select form-select-sm" name="sort" onchange="this.form.submit()">
                <option value="price-asc" <%= sortValue === 'price-asc' ? 'selected' : '' %>>Price: Low to High</option>
                <option value="price-desc" <%= sortValue === 'price-desc' ? 'selected' : '' %>>Price: High to Low</option>
                <option value="newest" <%= sortValue === 'newest' ? 'selected' : '' %>>Newest</option>
            </select>
        </form>
    </div>
</div>

<div class="d-flex flex-wrap gap-2 mb-4">
    <a href="/listings?category=Trending" class="filter-chip"><i class="fa-solid fa-fire"></i>Trending</a>
    <a href="/listings?category=Room" class="filter-chip"><i class="fa-solid fa-bed"></i>Room</a>
    <a href="/listings?category=Iconic Cities" class="filter-chip"><i class="fa-solid fa-city"></i>Iconic Cities</a>
    <a href="/listings?category=Mountains" class="filter-chip"><i class="fa-solid fa-mountain"></i>Mountains</a>
    <a href="/listings?category=Beaches" class="filter-chip"><i class="fa-solid fa-umbrella-beach"></i>Beaches</a>
    <a href="/listings?category=Camping" class="filter-chip"><i class="fa-solid fa-campground"></i>Camping</a>
    <a href="/listings?category=Villas" class="filter-chip"><i class="fa-solid fa-building-columns"></i>Villas</a>
</div>

<% if (activeCriteria && activeCriteria.length > 0) { %>
    <div class="d-flex flex-wrap gap-2 mb-3">
        <% for (let criterion of activeCriteria) { %><span class="badge rounded-pill bg-light text-dark border"><%= criterion %></span><% } %>
    </div>
<% } %>

<% if (allListings.length === 0) { %>
    <div class="text-center py-5 border rounded-4 bg-white shadow-sm">
        <h5 class="mb-2">No stays found for your search.</h5>
        <p class="text-muted mb-3">Try another destination or clear the current filters to browse all listings.</p>
        <a href="/listings" class="btn btn-outline-airbnb">Try another destination</a>
    </div>
<% } else { %>
    <div class="row row-cols-lg-3 row-cols-md-2 row-cols-1 g-4 mt-1">
        <% for (let listing of allListings) { %>
            <div class="col">
                <a href="/listings/<%=listing._id%>" class="listing-links">
                    <div class="card listing-card h-100">
                        <img src="<%= typeof listing.image === 'string' ? listing.image : (listing.image && listing.image.url ? listing.image.url : '') %>" class="card-img-top" alt="<%= listing.title %>" loading="lazy">
                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-start mb-2">
                                <div>
                                    <h5 class="card-title mb-1"><%= listing.title %></h5>
                                    <p class="text-muted mb-0"><%= listing.location %></p>
                                </div>
                                <span class="badge badge-soft rounded-pill">★ 4.9</span>
                            </div>
                            <p class="card-text mb-2"><strong>₹<%= listing.price ? listing.price.toLocaleString("en-IN") : '' %></strong> / night</p>
                            <div class="d-flex justify-content-between align-items-center text-muted small">
                                <span><i class="fa-solid fa-users me-1"></i>Up to <%= listing.guests || 4 %> guests</span>
                                <span><i class="fa-solid fa-sparkles me-1"></i>Superhost</span>
                            </div>
                        </div>
                    </div>
                </a>
            </div>
        <% } %>
    </div>
<% } %>