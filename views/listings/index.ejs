<% layout('layouts/boilerplate.ejs') %> 
<style>
  
.filters-container{
    display:flex;
    justify-content:space-between;
    align-items:center;
    margin-top:1rem;
}

#filters{
    display:flex;
    flex-wrap:wrap;
    gap:1.5rem;
}

.filter{
    text-decoration:none;
    color:black;
    text-align:center;
    opacity:0.7;
    transition:0.2s;
}

.filter:hover{
    opacity:1;
    cursor:pointer;
}

.tax-toggle{
    border:1px solid #ddd;
    border-radius:20px;
    padding:10px 15px;
    white-space:nowrap;
    display:flex;
    align-items:center;
    margin-left: 1rem;
}

.tax-info{
    display:none;
}
</style>

<!-- <h3>All Listings</h3> -->
 
 <div class="filters-container">

    <div id="filters">

        <a href="/listings?category=Trending" class="filter">
            <i class="fa-solid fa-fire"></i>
            <p>Trending</p>
        </a>

        <a href="/listings?category=Room" class="filter">
            <i class="fa-solid fa-bed"></i>
            <p>Room</p>
        </a>

        <a href="/listings?category=Iconic Cities" class="filter">
            <i class="fa-solid fa-mountain-city"></i>
            <p>Iconic Cities</p>
        </a>

        <a href="/listings?category=Mountains" class="filter">
            <i class="fa-solid fa-mountain"></i>
            <p>Mountains</p>
        </a>

        <a href="/listings?category=Castles" class="filter">
            <i class="fa-brands fa-fort-awesome"></i>
            <p>Castles</p>
        </a>

        <a href="/listings?category=Arctic" class="filter">
            <i class="fa-regular fa-snowflake"></i>
            <p>Arctic</p>
        </a>

        <a href="/listings?category=Beaches" class="filter">
            <i class="fa-solid fa-umbrella-beach"></i>
            <p>Beaches</p>
        </a>

        <a href="/listings?category=Camping" class="filter">
            <i class="fa-solid fa-campground"></i>
            <p>Camping</p>
        </a>

        <a href="/listings?category=Farms" class="filter">
            <i class="fa-solid fa-tractor"></i>
            <p>Farms</p>
        </a>

        <a href="/listings?category=Villas" class="filter">
            <i class="fa-solid fa-building-columns"></i>
            <p>Villas</p>
        </a>

        <a href="/listings?category=Boats" class="filter">
            <i class="fa-solid fa-ship"></i>
            <p>Boats</p>
        </a>

    </div>

    <div class="tax-toggle">

        <div class="form-check form-switch">
            <input class="form-check-input"
                   type="checkbox"
                   id="flexSwitchCheckDefault">

            <label class="form-check-label"
                   for="flexSwitchCheckDefault">
                Display Total After Taxes
            </label>
        </div>

    </div>

</div>

<!-- <form method="GET" action="/listings/new"> 
    <button>Create New Listing</button>
</form> -->
<div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-2 mt-4 mb-3">
    <div>
        <h4 class="mb-1">
            <% if (smartMode) { %>
                Smart search results
            <% } else { %>
                Discover stays
            <% } %>
        </h4>
        <p class="text-muted mb-0">
            <% if (searchQuery) { %>
                <%= resultCount %> stay<%= resultCount === 1 ? '' : 's' %> found for “<%= searchQuery %>”.
            <% } else { %>
                Browse the best stays for your next getaway.
            <% } %>
        </p>
    </div>

    <div class="d-flex align-items-center gap-2 flex-wrap">
        <% if (searchQuery) { %>
            <a href="/listings" class="btn btn-outline-secondary btn-sm">Clear search</a>
        <% } %>

        <form method="GET" action="/listings" class="d-flex align-items-center gap-2">
            <input type="hidden" name="search" value="<%= searchQuery %>">
            <input type="hidden" name="smart" value="<%= smartMode ? '1' : '' %>">
            <% if (selectedCategory) { %>
                <input type="hidden" name="category" value="<%= selectedCategory %>">
            <% } %>
            <select class="form-select form-select-sm" name="sort" onchange="this.form.submit()">
                <option value="price-asc" <%= sortValue === 'price-asc' ? 'selected' : '' %>>Price: Low to High</option>
                <option value="price-desc" <%= sortValue === 'price-desc' ? 'selected' : '' %>>Price: High to Low</option>
                <option value="newest" <%= sortValue === 'newest' ? 'selected' : '' %>>Newest</option>
            </select>
        </form>
    </div>
</div>

<% if (activeCriteria && activeCriteria.length > 0) { %>
    <div class="d-flex flex-wrap gap-2 mb-3">
        <% for (let criterion of activeCriteria) { %>
            <span class="badge rounded-pill bg-light text-dark border"><%= criterion %></span>
        <% } %>
    </div>
<% } %>

<% if (allListings.length === 0) { %>
    <div class="text-center py-5 border rounded-4 bg-light">
        <h5 class="mb-2">No stays found for your search.</h5>
        <p class="text-muted mb-3">Try another destination or clear the current filters to browse all listings.</p>
        <a href="/listings" class="btn btn-outline-secondary">Try another destination</a>
    </div>
<% } else { %>
    <div class="row row-cols-lg-3 row-cols-md-2 row-cols-sm-1 g-4 mt-1">
        <% for (let listing of allListings) { %>
            <a href="/listings/<%=listing._id%>" class="listing-links">
                <div class="card col">
           <img src="<%= typeof listing.image === 'string' ? listing.image : (listing.image && listing.image.url ? listing.image.url : '') %>" class="card-img-top" alt="listing_image" style="height: 12rem">
           <div class="card-img-overlay"></div>

                    <div class="card-body">
                        <p class="card-text">
                          <%= listing.title %> 
                          &#8377;<%= listing.price ? listing.price.toLocaleString("en-IN") : '' %> /night
                        </p>
                        <i class="tax-info">&nbsp;&nbsp;+18% GST</i>
            </div>
                </div>
            </a>
        <% } %>
    </div>
<% } %>


<script>
const taxSwitch = document.getElementById("flexSwitchCheckDefault");

taxSwitch.addEventListener("change", function () {

    const taxInfoElements = document.getElementsByClassName("tax-info");

    for (let info of taxInfoElements) {

        if (this.checked) {
            info.style.display = "inline";
        } else {
            info.style.display = "none";
        }

    }

});
</script>